    "e2e:sso": "tsx scripts/e2e-sso.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
