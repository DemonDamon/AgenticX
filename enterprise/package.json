{
  "name": "@agenticx/enterprise",
  "version": "0.1.0",
  "private": true,
  "description": "AgenticX Enterprise — 企业级大模型应用一体化平台（前台 + 后台 + AI 网关）",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
