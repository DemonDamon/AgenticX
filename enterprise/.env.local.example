NEXT_PUBLIC_SSO_PROVIDERS=default:企业统一认证
SSO_STATE_SIGNING_SECRET=replace-with-32-plus-bytes-random-secret
SSO_RETURN_TO_ALLOWLIST=/workspace,/dashboard
SSO_DEFAULT_ROLE_CODES=member
SSO_JIT_ROLE_ALLOWLIST=member,admin

SSO_OIDC_DEFAULT_ISSUER=https://idp.example.com/realms/agenticx
SSO_OIDC_DEFAULT_CLIENT_ID=agenticx-portal
SSO_OIDC_DEFAULT_CLIENT_SECRET=replace-with-client-secret
SSO_OIDC_DEFAULT_REDIRECT_URI=http://localhost:3000/api/auth/sso/oidc/callback
SSO_OIDC_DEFAULT_ADMIN_REDIRECT_URI=http://localhost:3001/api/auth/sso/oidc/callback
SSO_OIDC_DEFAULT_SCOPES=openid profile email groups
SSO_OIDC_DEFAULT_CLAIM_EMAIL=email
SSO_OIDC_DEFAULT_CLAIM_NAME=name
SSO_OIDC_DEFAULT_CLAIM_DEPT=department
SSO_OIDC_DEFAULT_CLAIM_ROLES=groups
SSO_OIDC_DEFAULT_CLAIM_EXTERNAL_ID=sub

# 可选：收紧 redirect_uri（admin-console 保存 provider 时校验）
# NEXT_PUBLIC_SSO_REDIRECT_ORIGIN_ALLOWLIST=http://localhost:3000,http://localhost:3001
# SSO_REDIRECT_REQUIRE_ISSUER_ORIGIN_MATCH=true
# 开发态非本机 http redirect 白名单（逗号分隔 origin），生产勿用
# SSO_DEV_INSECURE_REDIRECT_ALLOWLIST=

# Phase 4 provider secret encryption
SSO_PROVIDER_SECRET_KEY=replace-with-32-plus-byte-encryption-key

# SAML 双栈一键回退开关（仅关 SAML，不影响 OIDC）。
# 默认 false；设为 true 后 portal/admin 的 /api/auth/sso/saml/* 立即返回 saml.provider_not_configured，
# 同时管理台「新增 SAML provider」会被拒绝创建。详见 docs/runbooks/sso-saml-setup.md。
SSO_SAML_DISABLED=false

# 建议使用 openssl 生成:
# openssl rand -base64 32

# ============================================================
# 中移动 IDaaS（OIDC）接入模板
# ------------------------------------------------------------
# 实际对接前请向客户索取以下信息（M0 信息收集清单见
# docs/runbooks/sso-oidc-setup.md「中移动 IDaaS 接入信息收集清单」）。
# 客户尚未给出真实 issuer 时，请保留默认 https://idp.example.com 占位值，
# 让登录页稳定显示 `oidc.provider_not_configured` 错误码，避免误触 OIDC discovery。
# ------------------------------------------------------------
# NEXT_PUBLIC_SSO_PROVIDERS=cmcc-idaas:中移动统一身份
# SSO_OIDC_CMCC_IDAAS_ISSUER=https://<cmcc-idaas-host>/oauth2
# SSO_OIDC_CMCC_IDAAS_CLIENT_ID=<cmcc-idaas-client-id>
# SSO_OIDC_CMCC_IDAAS_CLIENT_SECRET=<cmcc-idaas-client-secret>
# SSO_OIDC_CMCC_IDAAS_REDIRECT_URI=http://localhost:3000/api/auth/sso/oidc/callback
# SSO_OIDC_CMCC_IDAAS_ADMIN_REDIRECT_URI=http://localhost:3001/api/auth/sso/oidc/callback
# SSO_OIDC_CMCC_IDAAS_SCOPES=openid profile email
# SSO_OIDC_CMCC_IDAAS_CLAIM_EMAIL=email
# SSO_OIDC_CMCC_IDAAS_CLAIM_NAME=name
# SSO_OIDC_CMCC_IDAAS_CLAIM_DEPT=department
# SSO_OIDC_CMCC_IDAAS_CLAIM_ROLES=roles
# SSO_OIDC_CMCC_IDAAS_CLAIM_EXTERNAL_ID=sub
# ============================================================
